# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# CORS Configuration
FRONTEND_URL=http://localhost:8080

# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:8080
CORS_ORIGINS=

# Server Configuration
HOST=0.0.0.0
PORT=8000
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_PRIMARY=llama3-8b-8192
GROQ_MODEL_FALLBACK=mixtral-8x7b-32768
GROQ_MAX_TOKENS=512
GROQ_TEMPERATURE=0.2

# ML Feature Explainability Source (Optional)
# If set, /api/ml/feature-importance/{employee_id} will read directly from this table first.
ML_FEATURE_TABLE=
ML_FEATURE_EMPLOYEE_KEY=employee_id
# Map canonical feature keys to your actual Supabase column names.
# Canonical keys: overtime_hours, pto_days_unused, meeting_load_hours, sentiment_score,
# tenure_months, performance_score, days_since_promotion, after_hours_ratio,
# communication_drop_indicator, engagement_score
ML_FEATURE_COLUMN_MAP_JSON={"overtime_hours":"avg_overtime_hours","pto_days_unused":"unused_pto_days","meeting_load_hours":"meeting_hours_weekly","sentiment_score":"sentiment_index","tenure_months":"tenure_months","performance_score":"kpi_completion_rate","days_since_promotion":"days_since_last_promotion","after_hours_ratio":"after_hours_work_ratio","communication_drop_indicator":"comm_drop_score","engagement_score":"engagement_index"}
