# Local development example: http://localhost:8000
# Production example: https://nova-backend.onrender.com
VITE_API_BASE_URL=

# Optional: enable Google OAuth via Supabase (if omitted, email/password auth still works)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Google Calendar OAuth client id from Google Cloud Console
VITE_GOOGLE_CALENDAR_CLIENT_ID=
